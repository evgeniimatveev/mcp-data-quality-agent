# ── DuckDB sources (local file paths) ────────────────────────────────────────
DUCKDB_SO_SURVEY=/path/to/so-survey-analytics/data/survey.duckdb
DUCKDB_OLIST=/path/to/olist-dbt-duckdb/olist.duckdb
DUCKDB_WEATHER=/path/to/weather-pipeline/data/weather.duckdb
